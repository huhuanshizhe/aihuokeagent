# ==================== AI 获客脚本环境变量 ====================
# 复制此文件为 .env 并填入实际的 API Key

# ---- 服务 API 鉴权 ----
# 公网部署必须设置；本地开发设置后，所有 /api/*（除 /api/health）需带：
#   Authorization: Bearer <SERVICE_API_KEY>  或  X-Api-Key: <SERVICE_API_KEY>
SERVICE_API_KEY=replace-with-a-long-random-secret
# 仅本地调试：true 时 /api/health 会返回 apiKey，供公开 API 测试页自动填入。公网切勿开启。
EXPOSE_API_KEY_IN_UI=false
# 浏览器调用时允许的 Origin，多个地址用逗号分隔；原生/线下客户端不受 CORS 影响。
CORS_ORIGINS=

# ---- AI 模型（主通道：阿里云百炼，中国内地/北京地域） ----
# 在百炼控制台创建 API Key；不要把真实密钥提交到 Git。
DASHSCOPE_API_KEY=sk-xxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DASHSCOPE_MODEL=qwen3.7-plus

# 兼容旧部署：若未设置上述 DASHSCOPE_*，仍会读取 TEXT_API_KEY、
# TEXT_BASE_URL 和 TEXT_MODEL。

# ---- AI 模型（备用通道） ----
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-plus

# ---- Google Places API ----
GOOGLE_MAPS_API_KEY=

# ---- Exa AI 搜索 ----
EXA_API_KEY=

# ---- Apollo.io B2B 数据库 ----
APOLLO_API_KEY=

# ---- Hunter.io 邮箱查找 ----
HUNTER_API_KEY=

# ---- SerpAPI (Google 搜索) ----
SERPAPI_KEY=

# ---- Brave Search API ----
BRAVE_SEARCH_API_KEY=

# ---- Firecrawl (可选，结构化网页提取) ----
FIRECRAWL_API_KEY=

# ---- 服务端口 ----
PORT=3100
